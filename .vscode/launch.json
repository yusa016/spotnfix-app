{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Start SpotN'Fix API",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/src/server.js",
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Seed Database",
      "cwd": "${workspaceFolder}/backend",
      "program": "${workspaceFolder}/backend/src/seed.js",
      "envFile": "${workspaceFolder}/backend/.env",
      "console": "integratedTerminal"
    }
  ],
  "compounds": [
    {
      "name": "API + Live Server",
      "configurations": ["Start SpotN'Fix API"],
      "preLaunchTask": "npm: install (backend)"
    }
  ]
}
